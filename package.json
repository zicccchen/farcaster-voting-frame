{
  "name": "farcaster-voting-frame",
  "version": "1.0.0",
  "description": "Farcaster Frame for on-chain voting",
  "scripts": {
    "dev": "node server.js",
    "deploy:contract": "npx hardhat run scripts/deploy.js --network localhost",
    "deploy:base:testnet": "npx hardhat run scripts/deploy-base.js --network baseSepolia",
    "deploy:base:mainnet": "npx hardhat run scripts/deploy-base.js --network base",
    "compile": "npx hardhat compile",
    "node": "npx hardhat node",
    "vercel:login": "npx vercel login",
    "vercel:deploy": "npx vercel",
    "vercel:prod": "npx vercel --prod"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0"
  }
}
